<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- SMS Permissions for reading and receiving transaction messages -->
    <uses-permission android:name="android.permission.READ_SMS" />
    <uses-permission android:name="android.permission.RECEIVE_SMS" />

    <!-- Notification permission for Android 13+ -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Alarm permissions -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Telephony hardware feature (optional for ChromeOS compatibility) -->
    <uses-feature android:name="android.hardware.telephony" android:required="false" />

    <!-- Internet permission for downloading AI model -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Biometric permission for app lock feature -->
    <uses-permission android:name="android.permission.USE_BIOMETRIC" />

    <!-- Explicitly remove AD_ID permission to ensure privacy -->
    <uses-permission android:name="com.google.android.gms.permission.AD_ID" tools:node="remove" />

    <application
        android:name=".CashiroApplication"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:enableOnBackInvokedCallback="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.CashiroCompose">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.Cashiro.SplashScreen"
            android:windowSoftInputMode="adjustResize">
        </activity>

        <activity-alias
            android:name=".MainActivityOriginal"
            android:enabled="true"
            android:exported="true"
            android:icon="@mipmap/ic_launcher_original"
            android:label="@string/app_name"
            android:roundIcon="@mipmap/ic_launcher_original_round"
            android:targetActivity=".MainActivity"
            android:theme="@style/Theme.Cashiro.SplashScreen.Original">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <meta-data
                android:name="android.app.shortcuts"
                android:resource="@xml/shortcuts" />
        </activity-alias>

        <activity-alias
            android:name=".MainActivityAnarchy"
            android:enabled="false"
            android:exported="true"
            android:icon="@mipmap/ic_launcher_anarchy"
            android:label="@string/app_name"
            android:roundIcon="@mipmap/ic_launcher_anarchy_round"
            android:targetActivity=".MainActivity"
            android:theme="@style/Theme.Cashiro.SplashScreen.Anarchy">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <meta-data
                android:name="android.app.shortcuts"
                android:resource="@xml/shortcuts" />
        </activity-alias>

        <activity-alias
            android:name=".MainActivityZenith"
            android:enabled="false"
            android:exported="true"
            android:icon="@mipmap/ic_launcher_zenith"
            android:label="@string/app_name"
            android:roundIcon="@mipmap/ic_launcher_zenith_round"
            android:targetActivity=".MainActivity"
            android:theme="@style/Theme.Cashiro.SplashScreen.Zenith">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <meta-data
                android:name="android.app.shortcuts"
                android:resource="@xml/shortcuts" />
        </activity-alias>
        
        <!-- Disable default WorkManager initialization -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>
        
        <!-- FileProvider for CSV export -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!-- SMS BroadcastReceiver for real-time transaction processing -->
        <receiver
            android:name=".receiver.SmsBroadcastReceiver"
            android:exported="true"
            android:permission="android.permission.BROADCAST_SMS">
            <intent-filter android:priority="999">
                <action android:name="android.provider.Telephony.SMS_RECEIVED" />
            </intent-filter>
        </receiver>

        <!-- Notification Action Receiver for handling notification button actions -->
        <receiver
            android:name=".receiver.NotificationActionReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.prarambha.cashiro.ACTION_DELETE_TRANSACTION" />
                <action android:name="com.prarambha.cashiro.ACTION_CONFIRM_TRANSACTION" />
            </intent-filter>
        </receiver>

        <!-- Reminder Receiver for daily alerts -->
        <receiver
            android:name=".receiver.ReminderReceiver"
            android:exported="false" />

        <!-- Boot Receiver for rescheduling alarms on reboot -->
        <receiver
            android:name=".receiver.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <!-- Quick Settings Tiles -->
        <service
            android:name=".service.AddTransactionTileService"
            android:exported="true"
            android:label="@string/add_transaction"
            android:icon="@drawable/ic_add_transaction"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

        <service
            android:name=".service.AddSubscriptionTileService"
            android:exported="true"
            android:label="@string/add_subscription"
            android:icon="@drawable/ic_add_subscription"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

        <service
            android:name=".service.AddTransferTileService"
            android:exported="true"
            android:label="@string/add_transfer"
            android:icon="@drawable/ic_transfer"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>
    </application>

</manifest>
